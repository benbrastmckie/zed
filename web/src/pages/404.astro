---
import PageLayout from "@layouts/PageLayout.astro";
import Container from "@components/ui/Container.astro";
import Button from "@components/ui/Button.astro";
---

<PageLayout title="Page Not Found" description="The page you are looking for could not be found.">
  <Container class="flex min-h-[60vh] flex-col items-center justify-center py-20 text-center">
    <p class="text-sm font-medium uppercase tracking-wider text-brand-600">404</p>
    <h1 class="mt-2 font-heading text-4xl font-bold text-[var(--text-heading)] sm:text-5xl">
      Page not found
    </h1>
    <p class="mt-4 max-w-md text-lg text-[var(--text-secondary)]">
      The page you are looking for does not exist or has been moved.
    </p>
    <div class="mt-8 flex gap-4">
      <Button href="/" variant="primary">Back to Home</Button>
    </div>
  </Container>
</PageLayout>
