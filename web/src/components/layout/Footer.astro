---
import { siteConfig } from "@data/site-config";

const currentYear = new Date().getFullYear();
---

<footer class="bg-warm-800 text-warm-200">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6 lg:px-8">
    <div class="grid gap-8 md:grid-cols-3">
      <!-- Brand -->
      <div>
        <a href="/" class="flex items-center gap-2.5" aria-label={`${siteConfig.title} home`}>
          <span class="font-heading text-lg font-bold text-warm-50">{siteConfig.title}</span>
        </a>
        <p class="mt-3 text-sm text-warm-400">
          {siteConfig.description}
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <h2 class="font-heading text-sm font-semibold uppercase tracking-wider text-warm-300">
          Navigate
        </h2>
        <ul class="mt-3 space-y-2" role="list">
          {siteConfig.navItems.map((item) => (
            <li>
              <a
                href={item.href}
                class="text-sm text-warm-400 transition-colors hover:text-warm-100"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Connect -->
      <div>
        <h2 class="font-heading text-sm font-semibold uppercase tracking-wider text-warm-300">
          Connect
        </h2>
        <ul class="mt-3 space-y-2" role="list">
          <li>
            <a
              href={siteConfig.github}
              class="text-sm text-warm-400 transition-colors hover:text-warm-100"
              target="_blank"
              rel="noopener noreferrer"
            >
              GitHub
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-10 border-t border-warm-700 pt-6">
      <p class="text-center text-xs text-warm-500">
        &copy; {currentYear} {siteConfig.title}. All rights reserved.
      </p>
    </div>
  </div>
</footer>
