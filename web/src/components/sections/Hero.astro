---
import Button from "@components/ui/Button.astro";
import Container from "@components/ui/Container.astro";
import { siteConfig } from "@data/site-config";
---

<section class="relative flex min-h-[90vh] items-center overflow-hidden bg-[var(--surface-page)]">
  <!-- Layered background gradients -->
  <div
    class="pointer-events-none absolute inset-0 overflow-hidden"
    aria-hidden="true"
  >
    <!-- Primary gradient orb -->
    <div
      class="absolute left-1/2 top-1/3 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-15 blur-3xl"
      style="background: radial-gradient(circle, var(--color-brand-100), transparent 70%);"
    >
    </div>
    <!-- Decorative gradient orbs for depth -->
    <div
      class="absolute top-1/4 left-1/4 h-96 w-96 rounded-full bg-brand-500/20 opacity-50 blur-3xl"
    >
    </div>
    <div
      class="absolute right-1/4 bottom-1/4 h-96 w-96 rounded-full bg-brand-400/10 opacity-30 blur-3xl"
    >
    </div>
  </div>

  <Container class="relative z-10 py-24 text-center md:py-32">
    <!-- Main heading -->
    <h1
      class="mx-auto max-w-4xl text-[clamp(2.25rem,4vw+0.5rem,4rem)] font-bold leading-[1.1] tracking-tight text-[var(--text-heading)]"
    >
      {siteConfig.title}
    </h1>
    <!-- Tagline -->
    <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-[var(--text-secondary)] md:text-xl">
      {siteConfig.description}
    </p>
    <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
      <Button href="/#features" variant="primary" size="lg">
        See Features
      </Button>
      <Button href="/contact" variant="ghost" size="lg">
        Get in Touch
      </Button>
    </div>
  </Container>
</section>
