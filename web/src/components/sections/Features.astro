---
import Container from "@components/ui/Container.astro";
import SectionHeading from "@components/ui/SectionHeading.astro";
import FeatureCard from "@components/ui/FeatureCard.astro";
import { features } from "@data/features";
---

<section id="features" class="bg-brand-50 py-24 dark:bg-brand-600/30 md:py-32">
  <Container>
    <SectionHeading
      title="Features"
      subtitle="Everything you need to build a fast, accessible, and beautiful website."
      align="left"
      decorative={true}
      subtitleClass="text-brand-400"
    />

    <div class="mt-12 grid gap-8 sm:grid-cols-2">
      {features.map((feature, index) => (
        <FeatureCard
          title={feature.title}
          description={feature.description}
          glass={true}
          class="scroll-reveal"
          style={`animation-delay: ${index * 100}ms`}
        />
      ))}
    </div>
  </Container>
</section>
