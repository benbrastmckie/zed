{
  // Zed Editor Settings
  // Platform: macOS 11 (Big Sur) or newer
  // No vim mode -- standard keybindings for all users
  "vim_mode": true,
  "theme": "One Dark",
  "base_keymap": "VSCode",
  "buffer_font_size": 14,
  "ui_font_size": 15,
  "buffer_font_family": "Fira Code",

  "tab_size": 2,
  "soft_wrap": "editor_width",
  "show_whitespaces": "none",
  "relative_line_numbers": "disabled",
  "cursor_blink": true,
  "scrollbar": {
    "show": "auto"
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "inlay_hints": {
    "enabled": true
  },

  // Telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // File and project settings
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/node_modules",
    "**/target",
    "**/.cache",
    "**/result"
  ],

  // Terminal
  "terminal": {
    "dock": "right",
    "shell": {
      "program": "bash"
    },
    "font_size": 13,
    "copy_on_select": true
  },

  // LSP settings
  "lsp": {
    "markdownlint": {
      "settings": {
        "MD013": false,
        "MD022": false,
        "MD032": false
      }
    },
    "pyright": {
      "settings": {
        "python.analysis": {
          "typeCheckingMode": "basic",
          "diagnosticMode": "openFilesOnly"
        }
      }
    },
    "r-language-server": {
      "settings": {
        "r": {
          "lsp": {
            "diagnostics": true,
            "rich_documentation": true
          }
        }
      }
    }
  },

  // Language-specific settings
  "languages": {
    "Markdown": {
      "soft_wrap": "editor_width",
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--parser", "markdown", "--prose-wrap", "never"]
        }
      }
    },
    "JSON": {
      "tab_size": 2
    },
    "JSONC": {
      "tab_size": 2
    },
    "TOML": {
      "tab_size": 2
    },
    "Nix": {
      "tab_size": 2
    },
    "Python": {
      "tab_size": 4,
      "language_servers": ["pyright", "ruff"],
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "ruff"
        }
      }
    },
    "R": {
      "tab_size": 2,
      "language_servers": ["r-language-server"],
      "format_on_save": "on",
      "formatter": {
        "language_server": {
          "name": "r-language-server"
        }
      }
    }
  },

  // Auto-install extensions
  "auto_install_extensions": {
    "markdown-oxide": true,
    "markdownlint": true,
    "codebook": true,
    "csv": true,
    "claude-code-extension": false,
    "nix": true,
    "toml": true,
    "git-firefly": true,
    "r": true,
    "python": true,
    "ruff": true
  },

  // Git integration
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 500
    }
  },

  // Formatter
  "format_on_save": "on",

  // Claude Code agent server (ACP)
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": [
          "bypassPermissions"
        ]
      },
      "default_config_options": {
        "mode": "bypassPermissions"
      },
      "type": "custom",
      // Bare `npx` lets macOS PATH resolve the binary. On Apple Silicon
      // Homebrew installs to /opt/homebrew/bin/npx; on Intel Macs it is
      // /usr/local/bin/npx. Substitute an absolute path here if PATH
      // resolution is unavailable (e.g., when launching Zed from Finder
      // without a login shell).
      "command": "npx",
      "args": ["@agentclientprotocol/claude-agent-acp", "--serve"],
      "env": {
        // `claude` is resolved from PATH. Homebrew default on Apple
        // Silicon is /opt/homebrew/bin/claude; on Intel, /usr/local/bin/claude.
        "CLAUDE_CODE_EXECUTABLE": "claude",
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
      }
    }
  },

  // Collaboration
  "collaboration_panel": {
    "button": false
  }
}
