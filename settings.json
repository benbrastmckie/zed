{
  // Zed Editor Settings
  // Platform: NixOS Linux (binary: zeditor)
  // No vim mode -- standard keybindings for all users
  "auto_reload_on_disk_change": true,

  "theme": "One Dark",
  "base_keymap": "VSCode",
  "buffer_font_size": 14,
  "ui_font_size": 15,
  "buffer_font_family": "Fira Code",

  "tab_size": 2,
  "soft_wrap": "preferred_line_length",
  "preferred_line_length": 100,
  "show_whitespaces": "none",
  "relative_line_numbers": "disabled",
  "cursor_blink": true,
  "scrollbar": {
    "show": "auto"
  },
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware"
  },
  "inlay_hints": {
    "enabled": true
  },

  // Telemetry
  "telemetry": {
    "diagnostics": false,
    "metrics": false
  },

  // Agent (AI) configuration
  "agent": {
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-20250514"
    },
    "inline_alternatives": [
      {
        "provider": "anthropic",
        "model": "claude-opus-4-20250514"
      }
    ],
  },

  // File and project settings
  "file_scan_exclusions": [
    "**/.git",
    "**/.svn",
    "**/node_modules",
    "**/target",
    "**/.cache",
    "**/result"
  ],

  // Terminal
  "terminal": {
    "shell": {
      "program": "bash"
    },
    "font_size": 13,
    "copy_on_select": true
  },

  // LSP settings
  "lsp": {
    "markdownlint": {
      "settings": {
        "MD013": false,
        "MD022": false,
        "MD032": false
      }
    }
  },

  // Language-specific settings
  "languages": {
    "Markdown": {
      "soft_wrap": "preferred_line_length",
      "preferred_line_length": 80,
      "tab_size": 2,
      "format_on_save": "on",
      "formatter": {
        "external": {
          "command": "prettier",
          "arguments": ["--parser", "markdown", "--prose-wrap", "never"]
        }
      }
    },
    "JSON": {
      "tab_size": 2
    },
    "JSONC": {
      "tab_size": 2
    },
    "TOML": {
      "tab_size": 2
    },
    "Nix": {
      "tab_size": 2
    },
    "Python": {
      "tab_size": 4
    },
    "R": {
      "tab_size": 2
    }
  },

  // Auto-install extensions
  "auto_install_extensions": {
    "markdown-oxide": true,
    "markdownlint": true,
    "codebook": true,
    "csv": true,
    "claude-code-extension": false,
    "nix": true,
    "toml": true,
    "git-firefly": true,
    "r": true
  },

  // Git integration
  "git": {
    "inline_blame": {
      "enabled": true,
      "delay_ms": 500
    }
  },

  // Formatter
  "format_on_save": "on",

  // Claude Code agent server (ACP)
  "agent_servers": {
    "claude-acp": {
      "favorite_config_option_values": {
        "mode": [
          "bypassPermissions"
        ]
      },
      "default_config_options": {
        "mode": "bypassPermissions"
      },
      "type": "custom",
      "command": "/home/benjamin/.nix-profile/bin/npx",
      "args": ["@agentclientprotocol/claude-agent-acp", "--serve"],
      "env": {
        "CLAUDE_CODE_EXECUTABLE": "/home/benjamin/.nix-profile/bin/claude",
        "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
        "HOME": "/home/benjamin"
      }
    }
  },

  // Collaboration
  "collaboration_panel": {
    "button": false
  }
}
