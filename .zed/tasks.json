[
  {
    // Full Claude Code CLI via terminal for complete feature parity
    // (subagents, --team mode, skills, hooks). Use this instead of the
    // agent panel when you need the full CLI experience.
    "label": "Claude Code",
    "command": "claude",
    "args": ["--dangerously-skip-permissions"],
    "use_new_terminal": true,
    "allow_concurrent_runs": true,
    "reveal": "always",
    "reveal_target": "dock"
  },
  {
    // Build PDF from the current file (Typst or Slidev).
    // Dispatches by file extension: .typ -> typst compile, .md -> slidev export.
    // Bound to Alt+Shift+E in keymap.json.
    "label": "Build PDF",
    "command": ".zed/scripts/build-pdf.sh \"$ZED_FILE\"",
    "args": [],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "never",
    "reveal_target": "dock",
    "hide": "always"
  },
  {
    // Live preview in browser (long-running server).
    // Dispatches by file extension: .typ -> tinymist preview, .md -> slidev dev.
    // Bound to Alt+Shift+P in keymap.json.
    "label": "Preview in Browser",
    "command": ".zed/scripts/preview.sh \"$ZED_FILE\"",
    "args": [],
    "use_new_terminal": false,
    "allow_concurrent_runs": false,
    "reveal": "never",
    "reveal_target": "dock",
    "hide": "always"
  }
]
