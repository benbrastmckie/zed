[
  // =====================================================
  // CUSTOM BINDINGS (Scheme A -- Minimal)
  // =====================================================
  // 7 unique custom bindings (8 entries; Claude Code launcher
  // is bound in both Workspace and Terminal contexts):
  //   - 2 pane navigation (Ctrl+H, Ctrl+L)
  //   - 2 line movers (Alt+J, Alt+K)
  //   - 1 dock toggle (Ctrl+?)
  //   - 1 Claude Code launcher (Ctrl+Shift+A, in 2 contexts)
  //   - 1 copy path utility (Ctrl+Shift+C)
  //
  // All custom bindings intentionally use Ctrl+ (not Cmd+) on
  // macOS so they do not collide with Zed's built-in Cmd+
  // shortcuts. See ZED DEFAULT REFERENCE below for the macOS
  // defaults this config leaves intact.

  // Pane navigation (move focus between split panes)
  {
    "context": "Workspace",
    "bindings": {
      "ctrl-h": "workspace::ActivatePaneLeft",
      "ctrl-l": "workspace::ActivatePaneRight",
      "ctrl-?": "workspace::ToggleRightDock",
      "ctrl-shift-a": ["task::Spawn", { "task_name": "Claude Code" }]
    }
  },

  // Claude Code from terminal context
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-shift-a": ["task::Spawn", { "task_name": "Claude Code" }]
    }
  },

  // Line movers (move current line up/down)
  {
    "context": "Editor",
    "bindings": {
      "alt-j": "editor::MoveLineDown",
      "alt-k": "editor::MoveLineUp",
      "ctrl-shift-c": "editor::CopyPath"
    }
  }

  // =====================================================
  // ZED DEFAULT REFERENCE (macOS)
  // =====================================================
  // These are built-in Zed shortcuts on macOS -- no config
  // needed. Listed here for quick reference. Entries marked
  // (custom) are NOT Zed defaults; they are rebindings from
  // the CUSTOM BINDINGS block above and are listed here so
  // the exception is visible alongside the default table.
  // Entries marked (verify) are best-guess macOS defaults
  // that should be confirmed against Zed's keymap docs
  // before relying on them.
  //
  // --- File Operations ---
  // Cmd+P             Open file by name (file finder)
  // Cmd+S             Save file
  // Cmd+Shift+S       Save all files (verify)
  // Cmd+N             New file
  // Cmd+W             Close active tab
  // Cmd+Shift+T       Reopen closed tab
  //
  // --- Navigation ---
  // Ctrl+Tab          Next tab (platform-agnostic in Zed)
  // Ctrl+Shift+Tab    Previous tab (platform-agnostic in Zed)
  // Ctrl+G            Go to line number
  // Cmd+Shift+O       Go to symbol in file
  // F12               Go to definition
  // Ctrl+-            Go back (previous location) (verify)
  // Ctrl+Shift+-      Go forward (next location) (verify)
  //
  // --- Panels & Sidebars ---
  // Cmd+B             Toggle left sidebar
  // Cmd+Shift+E       File explorer (project panel)
  // Cmd+Shift+G       Git panel (verify)
  // Ctrl+`            Toggle terminal (Ctrl+ on macOS too)
  // Cmd+Shift+M       Problems panel (verify)
  //
  // --- Search ---
  // Cmd+F             Find in file
  // Cmd+Alt+F         Find and replace in file (verify)
  // Cmd+Shift+F       Search across all files
  // Cmd+Shift+H       Replace across all files (verify)
  //
  // --- Agent / AI ---
  // Ctrl+Shift+A      Launch Claude Code CLI (custom; terminal task)
  // Ctrl+?            Toggle right dock (custom; see Workspace bindings)
  // Cmd+?             Toggle agent panel (verify)
  // Cmd+N             New conversation (in agent panel) (verify)
  // Cmd+Enter         Send message (in agent panel) (verify)
  // Cmd+;             Toggle inline assist (verify)
  //
  // --- Editing ---
  // Cmd+Z             Undo
  // Cmd+Shift+Z       Redo
  // Cmd+C             Copy
  // Cmd+X             Cut
  // Cmd+V             Paste
  // Cmd+D             Select next occurrence
  // Ctrl+Shift+K      Delete line (verify; may be Cmd+Shift+K)
  // Cmd+/             Toggle comment
  // Cmd+]             Indent line
  // Cmd+[             Outdent line
  // Cmd+Alt+Up        Add cursor above (verify)
  // Cmd+Alt+Down      Add cursor below (verify)
  // Ctrl+Shift+C      Copy path (custom; see Editor bindings)
  //
  // --- Code Actions ---
  // Cmd+.             Quick fix / code actions
  // F2                Rename symbol
  // Ctrl+Space        Trigger autocomplete
  // Cmd+Shift+I       Format document (verify)
  //
  // --- Pane Navigation ---
  // Ctrl+H            ActivatePaneLeft (custom; see Workspace bindings)
  // Ctrl+L            ActivatePaneRight (custom; see Workspace bindings)
  //
  // --- Git ---
  // Alt+G B           Toggle git blame
  //
  // --- Markdown ---
  // Cmd+K V           Markdown preview (side-by-side) (verify)
  // Cmd+Shift+V       Markdown preview (full tab) (verify)
  //
  // --- Window Management ---
  // Cmd+\             Split pane right (verify)
  // Cmd+Shift+\       Split pane down (verify)
  // Cmd+Shift+P       Command palette
  // Cmd+,             Open settings
]
