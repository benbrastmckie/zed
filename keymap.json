[
  // =====================================================
  // CUSTOM BINDINGS (Scheme A -- Minimal)
  // =====================================================
  // 14 unique custom bindings (25 entries across contexts).
  //
  // Modifier categories:
  //
  //   secondary- (platform-adaptive: Ctrl on Linux, Cmd on macOS)
  //     - 1 left dock / explorer (Secondary+Shift+E), Workspace + Editor
  //     - 1 copy path (Secondary+Shift+C)
  //     - 1 open file under cursor (Secondary+Enter)
  //
  //   cmd- (Cmd on macOS)
  //     - 2 pane navigation (Cmd+H, Cmd+L), Workspace + Editor + Terminal
  //     - 2 jump list (Cmd+O, Cmd+I), Workspace + Editor (overrides Cmd+O Open)
  //     - 1 Claude Code launcher (Cmd+Shift+A), Workspace + Editor + Terminal
  //
  //   ctrl- (fixed Ctrl on ALL platforms, including macOS)
  //     - 2 line movers (Ctrl+J, Ctrl+K), Editor
  //     - 1 close tab (Ctrl+Q), Workspace + Editor
  //
  //   alt- (Opt on macOS)
  //     - 1 vim toggle (Opt+V), Workspace
  //     (line movers Ctrl+J, Ctrl+K are under ctrl- below)
  //     - 1 reload file from disk (Opt+R)
  //     - 1 preview in browser (Opt+Shift+E) -- Typst/Slidev dispatcher
  //     - 1 build PDF (Opt+Shift+P) -- Typst/Slidev dispatcher
  //
  // The ctrl- bindings intentionally remain Ctrl (not Cmd) on
  // macOS to avoid collisions with Zed defaults (e.g. Cmd+Q
  // quits the app). See ZED DEFAULT REFERENCE below for the
  // macOS defaults this config leaves intact.

  // Pane navigation (move focus between split panes)
  // Jump list: Cmd+O / Cmd+I (vim-style back/forward without vim mode)
  // Vim toggle: Opt+V
  {
    "context": "Workspace",
    "bindings": {
      "cmd-h": "workspace::ActivatePaneLeft",
      "cmd-l": "workspace::ActivatePaneRight",
      "secondary-shift-e": "workspace::ToggleLeftDock",
      "secondary-shift-c": "workspace::CopyPath",
      "cmd-shift-a": ["task::Spawn", { "task_name": "Claude Code" }],
      "ctrl-q": "pane::CloseActiveItem",
      "cmd-o": "pane::GoBack",
      "cmd-i": "pane::GoForward",
      "alt-v": "workspace::ToggleVimMode",
      "cmd-shift-b": "editor::ToggleGitBlame"
    }
  },

  // Claude Code from terminal context
  {
    "context": "Terminal",
    "bindings": {
      "cmd-shift-a": ["task::Spawn", { "task_name": "Claude Code" }],
      "cmd-h": "workspace::ActivatePaneLeft",
      "cmd-l": "workspace::ActivatePaneRight"
    }
  },

  // Editor-context overrides
  //
  // Cmd+H and Cmd+L are re-declared here so that Zed's default
  // Cmd+H (hide application) and any Editor-context bindings do not
  // shadow the Workspace-context pane-navigation binding above.
  {
    "context": "Editor",
    "bindings": {
      "ctrl-j": "editor::MoveLineDown",
      "ctrl-k": "editor::MoveLineUp",
      "ctrl-q": "pane::CloseActiveItem",
      "cmd-h": "workspace::ActivatePaneLeft",
      "cmd-l": "workspace::ActivatePaneRight",
      "cmd-o": "pane::GoBack",
      "cmd-i": "pane::GoForward",
      "cmd-shift-a": ["task::Spawn", { "task_name": "Claude Code" }],
      "secondary-shift-c": "workspace::CopyPath",
      "secondary-shift-e": "workspace::ToggleLeftDock",
      "alt-shift-e": ["task::Spawn", { "task_name": "Preview in Browser" }],
      "alt-shift-p": ["task::Spawn", { "task_name": "Build PDF" }],
      "secondary-enter": "editor::OpenFile",
      "alt-r": "editor::ReloadFile",
      "cmd->": "editor::Indent",
      "cmd-<": "editor::Outdent"
    }
  },

  // Project panel hjkl navigation (vim-style without vim mode)
  //
  // Provides h/j/k/l movement inside the file explorer while
  // leaving vim mode disabled globally. Guarded by `not_editing`
  // so the inline rename input (F2) still receives literal keys.
  //   h -- collapse current directory (or move to parent)
  //   j -- select next entry
  //   k -- select previous entry
  //   l -- open file, or expand/collapse directory
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "h": "project_panel::CollapseSelectedEntry",
      "j": "menu::SelectNext",
      "k": "menu::SelectPrevious",
      "l": "project_panel::Open",
    }
  }

  // =====================================================
  // ZED DEFAULT REFERENCE (macOS)
  // =====================================================
  // These are built-in Zed shortcuts on macOS -- no config
  // needed. Listed here for quick reference. Entries marked
  // (custom) are NOT Zed defaults; they are rebindings from
  // the CUSTOM BINDINGS block above and are listed here so
  // the exception is visible alongside the default table.
  // Entries marked (verify) are best-guess macOS defaults
  // that should be confirmed against Zed's keymap docs
  // before relying on them.
  //
  // --- File Operations ---
  // Cmd+P             Open file by name (file finder)
  // Cmd+S             Save file
  // Cmd+Shift+S       Save all files (verify)
  // Cmd+N             New file
  // Cmd+W             Close active tab
  // Cmd+Shift+T       Reopen closed tab
  //
  // --- Navigation ---
  // Ctrl+Tab          Next tab (platform-agnostic in Zed)
  // Ctrl+Shift+Tab    Previous tab (platform-agnostic in Zed)
  // Ctrl+G            Go to line number
  // Cmd+Shift+O       Go to symbol in file
  // F12               Go to definition
  // Cmd+O             Go back in jump list (custom; overrides Open file)
  // Cmd+I             Go forward in jump list (custom)
  // Ctrl+-            Go back (previous location) (verify)
  // Ctrl+Shift+-      Go forward (next location) (verify)
  //
  // --- Panels & Sidebars ---
  // Cmd+B             Toggle left sidebar
  // Secondary+Shift+E File explorer / toggle left dock (custom; overrides project_panel::ToggleFocus on macOS)
  // Cmd+Shift+G       Git panel (verify)
  // Ctrl+`            Toggle terminal (Ctrl+ on macOS too)
  // Cmd+Shift+M       Problems panel (verify)
  //
  // --- Search ---
  // Cmd+F             Find in file
  // Cmd+Opt+F         Find and replace in file (verify)
  // Cmd+Shift+F       Search across all files
  // Cmd+Shift+H       Replace across all files (verify)
  //
  // --- Agent / AI ---
  // Cmd+Shift+A       Launch Claude Code CLI (custom; terminal task)
  // Cmd+R             Toggle right dock (Zed default)
  // Cmd+?             Toggle agent panel (verify)
  // Cmd+N             New conversation (in agent panel) (verify)
  // Cmd+Enter         Send message (in agent panel) (verify)
  // Cmd+;             Toggle inline assist (verify)
  //
  // --- Navigation ---
  // Secondary+Enter   Open file under cursor (custom; secondary- = Ctrl on Linux, Cmd on macOS)
  //
  // --- Build / Preview (Typst + Slidev) ---
  // Opt+Shift+E         Preview in Browser (custom; dispatches by file extension)
  // Opt+Shift+P         Build PDF (custom; dispatches by file extension)
  //
  // --- Mode ---
  // Opt+V             Toggle vim mode (custom)
  //
  // --- Editing ---
  // Cmd+Z             Undo
  // Cmd+Shift+Z       Redo
  // Cmd+C             Copy
  // Cmd+X             Cut
  // Cmd+V             Paste
  // Cmd+D             Select next occurrence
  // Ctrl+Shift+K      Delete line (verify; may be Cmd+Shift+K)
  // Cmd+/             Toggle comment
  // Cmd+>             Indent line (custom; replaces Cmd+])
  // Cmd+<             Outdent line (custom; replaces Cmd+[)
  // Cmd+Opt+Up        Add cursor above (verify)
  // Cmd+Opt+Down      Add cursor below (verify)
  // Secondary+Shift+C Copy path (custom; secondary- = Ctrl on Linux, Cmd on macOS)
  //
  // --- Code Actions ---
  // Cmd+.             Quick fix / code actions
  // F2                Rename symbol
  // Ctrl+Space        Trigger autocomplete
  // Cmd+Shift+I       Format document (verify)
  //
  // --- Pane Navigation ---
  // Cmd+H             ActivatePaneLeft (custom; overrides macOS Hide)
  // Cmd+L             ActivatePaneRight (custom)
  //
  // --- Git ---
  // Cmd+Shift+B       Toggle git blame (custom; replaces Opt+G B chord)
  //
  // --- Markdown ---
  // Cmd+Shift+V       Markdown preview (full tab) (verify)
  // (Cmd+K V chord removed -- use command palette instead)
  //
  // --- Window Management ---
  // Cmd+\             Split pane right (verify)
  // Cmd+Shift+\       Split pane down (verify)
  // Cmd+Shift+P       Command palette
  // Cmd+,             Open settings
]
